{
  "id": "carousel",
  "href": "/docs/components/carousel",
  "exportHref": "/ai/components/carousel.json",
  "title": "Carousel",
  "description": "Swipeable slide gallery with indicators and navigation arrows.",
  "category": "Layout",
  "importName": "Carousel",
  "parts": [
    "base"
  ],
  "props": [
    {
      "name": "label",
      "type": "string",
      "required": true,
      "description": "Accessible label"
    },
    {
      "name": "children",
      "type": "ReactNode",
      "description": "Slide elements"
    },
    {
      "name": "size",
      "type": "'xs' | 'sm' | 'md' | 'lg' | 'xl'",
      "default": "'md'",
      "description": "Component size"
    },
    {
      "name": "className",
      "type": "string",
      "description": "CSS class on host element"
    },
    {
      "name": "style",
      "type": "React.CSSProperties",
      "description": "Inline styles on host element"
    },
    {
      "name": "ref",
      "type": "React.Ref<HTMLElement>",
      "description": "Ref forwarded to Custom Element"
    }
  ]
}
