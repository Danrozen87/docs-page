{
  "id": "thinking",
  "href": "/docs/components/thinking",
  "exportHref": "/ai/components/thinking.json",
  "title": "Thinking",
  "description": "Animated thinking/loading indicator with shimmer effect. Designed for AI chat interfaces.",
  "category": "Feedback",
  "importName": "Thinking",
  "variants": [
    "ghost",
    "filled"
  ],
  "shapes": [
    "sharp",
    "rounded",
    "pill"
  ],
  "parts": [
    "base"
  ],
  "props": [
    {
      "name": "label",
      "type": "string",
      "description": "Accessible label"
    },
    {
      "name": "variant",
      "type": "'ghost' | 'filled'",
      "default": "'ghost'",
      "description": "Visual treatment"
    },
    {
      "name": "shape",
      "type": "'sharp' | 'rounded' | 'pill'",
      "default": "'rounded'",
      "description": "Border radius"
    },
    {
      "name": "speed",
      "type": "string",
      "description": "Animation speed"
    },
    {
      "name": "size",
      "type": "'xs' | 'sm' | 'md' | 'lg' | 'xl'",
      "default": "'md'",
      "description": "Component size"
    },
    {
      "name": "className",
      "type": "string",
      "description": "CSS class on host element"
    },
    {
      "name": "style",
      "type": "React.CSSProperties",
      "description": "Inline styles on host element"
    },
    {
      "name": "ref",
      "type": "React.Ref<HTMLElement>",
      "description": "Ref forwarded to Custom Element"
    }
  ]
}
