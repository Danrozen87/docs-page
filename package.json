    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
